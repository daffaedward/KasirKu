{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "resolveJsonModule": true,
    "isolatedModules": true,
    
    "types": ["bun"]
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules", "cert", "database"]
}